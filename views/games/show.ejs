<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Show Page</title>
</head>
<body>
    <h1><%= game.title %> </h1>
    <p>A game by <%= game.creator %> for <%= game.minPlayers %> to <%= game.maxPlayers %> players. </p>

    <% if (game.publisher) { %>
    <p>Published by <%= game.publisher %>  </p>
    <% } %>

    <p><%= game.description %> </p>

    <% if (game.gm) { %>
    <p>Requires a GM or facilitator</p>
    <% } else { %>
    <p>No GM or facilitator necessary</p>
    <% } %>
     

    <% if (game.link) { %>
        <a href="<%= game.link %> ">See website</a>
    <% } %>


</body>
</html>